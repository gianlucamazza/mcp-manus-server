# Environment Configuration
NODE_ENV=development
LOG_LEVEL=info

# OAuth 2.1 Configuration
OAUTH_CLIENT_ID=your_client_id_here
OAUTH_CLIENT_SECRET=your_client_secret_here
OAUTH_REDIRECT_URI=http://localhost:3000/oauth/callback
OAUTH_AUTH_URL=https://api.manus.im/oauth/authorize
OAUTH_TOKEN_URL=https://api.manus.im/oauth/token
OAUTH_SCOPES=read,write

# Manus.im API Configuration
MANUS_API_KEY=your_manus_api_key_here
MANUS_API_URL=https://api.manus.run

# Security Configuration
JWT_SECRET=your_very_secure_random_string_here_change_in_production

# Docker Configuration
COMPOSE_PROJECT_NAME=mcp_manus
COMPOSE_FILE=docker/docker-compose.yml