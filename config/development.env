# Development Environment Configuration
NODE_ENV=development
LOG_LEVEL=debug

# Server Configuration
PORT=3000
HOST=localhost
BASE_URL=http://localhost:3000
RESOURCE_IDENTIFIER=http://localhost:3000/api/v1/

# OAuth 2.1 Configuration
OAUTH_CLIENT_ID=dev_client_id
OAUTH_CLIENT_SECRET=dev_client_secret_change_in_production
OAUTH_REDIRECT_URI=http://localhost:3000/oauth/callback
OAUTH_AUTH_URL=http://localhost:3000/oauth/authorize
OAUTH_TOKEN_URL=http://localhost:3000/oauth/token
OAUTH_SCOPES=read,write

# Manus.im API Configuration (Development)
MANUS_API_KEY=dev_manus_api_key
MANUS_API_URL=https://api.manus.run

# Security Configuration
JWT_SECRET=dev_jwt_secret_at_least_256_bits_long_change_in_production
BCRYPT_ROUNDS=10

# Database Configuration (if needed)
DATABASE_URL=postgresql://localhost:5432/mcp_manus_dev
REDIS_URL=redis://localhost:6379

# Monitoring Configuration
METRICS_ENABLED=true
METRICS_PORT=9090

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true

# Development Features
HOT_RELOAD=true
DEBUG_SQL=true
MOCK_EXTERNAL_APIS=true