# Production Environment Configuration
NODE_ENV=production
LOG_LEVEL=warn

# Server Configuration
PORT=3000
HOST=0.0.0.0
BASE_URL=https://mcp-manus.example.com
RESOURCE_IDENTIFIER=https://api.manus.im/v1/

# OAuth 2.1 Configuration
OAUTH_CLIENT_ID=${PROD_OAUTH_CLIENT_ID}
OAUTH_CLIENT_SECRET=${PROD_OAUTH_CLIENT_SECRET}
OAUTH_REDIRECT_URI=https://mcp-manus.example.com/oauth/callback
OAUTH_AUTH_URL=https://api.manus.im/oauth/authorize
OAUTH_TOKEN_URL=https://api.manus.im/oauth/token
OAUTH_SCOPES=read,write

# Manus.im API Configuration (Production)
MANUS_API_KEY=${PROD_MANUS_API_KEY}
MANUS_API_URL=https://api.manus.run

# Security Configuration
JWT_SECRET=${PROD_JWT_SECRET}
BCRYPT_ROUNDS=14

# Database Configuration
DATABASE_URL=${PROD_DATABASE_URL}
DATABASE_SSL=true
DATABASE_MAX_CONNECTIONS=20
REDIS_URL=${PROD_REDIS_URL}
REDIS_TLS=true

# Monitoring Configuration
METRICS_ENABLED=true
METRICS_PORT=9090
PROMETHEUS_ENDPOINT=${PROD_PROMETHEUS_ENDPOINT}
GRAFANA_ENDPOINT=${PROD_GRAFANA_ENDPOINT}

# Rate Limiting (Production limits)
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_STORAGE=redis

# CORS Configuration
CORS_ORIGIN=https://mcp-manus.example.com,https://app.manus.im
CORS_CREDENTIALS=true

# Security Headers
HSTS_MAX_AGE=63072000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true
CSP_DIRECTIVES=default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-ancestors 'none';

# Performance
CLUSTER_MODE=true
WORKER_PROCESSES=auto
KEEP_ALIVE_TIMEOUT=65000
HEADERS_TIMEOUT=66000

# External Services
SENTRY_DSN=${PROD_SENTRY_DSN}
SENTRY_ENVIRONMENT=production
NEW_RELIC_LICENSE_KEY=${PROD_NEW_RELIC_KEY}
NEW_RELIC_APP_NAME=mcp-manus-production

# Backup and Recovery
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=${PROD_BACKUP_BUCKET}

# SSL/TLS
SSL_CERT_PATH=/etc/ssl/certs/mcp-manus.crt
SSL_KEY_PATH=/etc/ssl/private/mcp-manus.key
SSL_CA_PATH=/etc/ssl/certs/ca-certificates.crt

# Health Checks
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30000
READINESS_TIMEOUT=10000
LIVENESS_TIMEOUT=5000