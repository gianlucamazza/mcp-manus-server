# Staging Environment Configuration
NODE_ENV=staging
LOG_LEVEL=info

# Server Configuration
PORT=3000
HOST=0.0.0.0
BASE_URL=https://staging-mcp-manus.example.com
RESOURCE_IDENTIFIER=https://staging-api.manus.im/v1/

# OAuth 2.1 Configuration
OAUTH_CLIENT_ID=${STAGING_OAUTH_CLIENT_ID}
OAUTH_CLIENT_SECRET=${STAGING_OAUTH_CLIENT_SECRET}
OAUTH_REDIRECT_URI=https://staging-mcp-manus.example.com/oauth/callback
OAUTH_AUTH_URL=https://staging-api.manus.im/oauth/authorize
OAUTH_TOKEN_URL=https://staging-api.manus.im/oauth/token
OAUTH_SCOPES=read,write

# Manus.im API Configuration (Staging)
MANUS_API_KEY=${STAGING_MANUS_API_KEY}
MANUS_API_URL=https://staging-api.manus.run

# Security Configuration
JWT_SECRET=${STAGING_JWT_SECRET}
BCRYPT_ROUNDS=12

# Database Configuration
DATABASE_URL=${STAGING_DATABASE_URL}
REDIS_URL=${STAGING_REDIS_URL}

# Monitoring Configuration
METRICS_ENABLED=true
METRICS_PORT=9090
PROMETHEUS_ENDPOINT=http://prometheus-staging:9090

# Rate Limiting (More restrictive for staging)
RATE_LIMIT_REQUESTS=50
RATE_LIMIT_WINDOW_MS=60000

# CORS Configuration
CORS_ORIGIN=https://staging-mcp-manus.example.com
CORS_CREDENTIALS=true

# Security Headers
HSTS_MAX_AGE=31536000
CSP_DIRECTIVES=default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'

# Performance
CLUSTER_MODE=false
WORKER_PROCESSES=2

# External Services
SENTRY_DSN=${STAGING_SENTRY_DSN}
NEW_RELIC_LICENSE_KEY=${STAGING_NEW_RELIC_KEY}